<launch>
  <!-- Arguments -->
  <arg name="model" default="burger"/>
  <arg name="open_rviz" default="true"/>
  <arg name="move_forward_only" default="false"/>

  <!-- maps -->
  <!-- Add argument to launch your own yaml map here. -->
  <arg name="map_file" default="$(find custom_gazebo_world)/maps/karto_map.yaml"/>

  <!-- rviz -->
  <!-- Add argument to launch your own RViz configuration here.
  Then, call the rviz node with that argument. -->
  <arg name="rviz_config" default="$(find path_planning)/rviz/karto_map.rviz"/>
  <node pkg="rviz" name="rviz" type="rviz" args="-d $(arg rviz_config)"/>


  <!-- Map server -->
  <node pkg="map_server" name="map_server" type="map_server" args="$(arg map_file)">
    <param name="frame_id" value="map" />
  </node>

  <!-- Static tf between map and odom -->
  <arg name="static_tf" default="true" />
  <node if="$(arg static_tf)" pkg="tf2_ros" type="static_transform_publisher" name="odom_wrt_map_tf" args="0 0 0 0 0 0 map odom" />

  <!-- move_base -->
  <include file="$(find path_planning)/launch/move_base.launch">
    <arg name="model" value="$(arg model)" />
    <arg name="move_forward_only" value="$(arg move_forward_only)"/>
  </include>

  <!-- AMCL -->
  <!-- Add AMCL here, so you can estimate the robot's path on first launch. -->
  <node pkg="amcl" type="amcl" name="amcl" output="screen">
    <param name="use_map_topic" value="true" />
    
    <param name="initial_pose_x" value="2.752904563082006"/>
    <param name="initial_pose_y" value="-2.754354477828065"/>
    <param name="initial_pose_a" value="0"/>
    <param name="initial_cov_xx" value="0.24765850579898974"/> 
    <param name="initial_cov_yy" value="0.24290098927393622"/>
    <param name="initial_cov_aa" value="0.06716567243247021"/> 
  </node>
  <!-- Start service server that responds with a plan for global path planning -->
  <!-- algorithm: "standard" or "smoothed" -->
  <arg name="algorithm" default="standard"/>
  <node pkg="path_planning" name="path_planner" type="path_planning.py" output="screen">
    <param name="algorithm" value="$(arg algorithm)"/>
  </node>

</launch> 
